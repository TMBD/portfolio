---
/**
 * Layout — the shared page shell used by every page:
 *  - <head> metadata (title, description, canonical, Open Graph, fonts)
 *  - a no-flash script that applies the saved/system theme before paint
 *  - a first-visit language auto-detect redirect (French browsers → /fr)
 *  - the Header, a <slot> for page content, and the Footer.
 */
import "../styles/global.css";
import { languages, type Lang } from "../i18n/ui";
import { getLangFromUrl, getAlternatePath } from "../i18n/utils";
import { siteName } from "../config/site";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description?: string;
  /** OG image path in /public. */
  image?: string;
  /** Optional per-locale override URLs for the language switcher. */
  localeAlternates?: Partial<Record<Lang, string>>;
}

const lang = getLangFromUrl(Astro.url);
const { title, description = "", image = "/og.svg", localeAlternates } = Astro.props;
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;

// Localized alternates for hreflang tags (per-page override wins, else map URL).
const hreflangs = (Object.keys(languages) as Lang[]).map((l) => ({
  lang: l,
  href: localeAlternates?.[l] ?? getAlternatePath(Astro.url.pathname, l),
}));
const rssHref = lang === "fr" ? "/fr/rss.xml" : "/rss.xml";
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- RSS auto-discovery -->
    <link rel="alternate" type="application/rss+xml" title={`${siteName} — Blog`} href={rssHref} />

    <!-- hreflang alternates for bilingual SEO -->
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.lang} href={h.href} />)}

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={lang === "fr" ? "fr_FR" : "en_US"} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonicalURL)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400..700&family=Inter:opsz,wght@14..32,100..900&family=Space+Grotesk:wght@400..700&display=swap"
      rel="stylesheet"
    />

    <!-- No-flash theme: set the class BEFORE first paint to avoid a flash. -->
    <script is:inline>
      (function () {
        // Mark JS available (gates the scroll-reveal so no-JS users see content).
        document.documentElement.classList.add("js");
        try {
          var stored = localStorage.getItem("theme");
          var theme =
            stored ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light");
          document.documentElement.classList.toggle("dark", theme === "dark");
          document.documentElement.style.colorScheme = theme;
        } catch (e) {}
      })();
    </script>

    <!-- First-visit language auto-detect: redirect French browsers to /fr,
         unless the visitor has already chosen a language. -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem("lang")) return;
          var path = location.pathname;
          var isFr = path === "/fr" || path.indexOf("/fr/") === 0;
          var prefersFr =
            (navigator.language || "").toLowerCase().indexOf("fr") === 0;
          if (prefersFr && !isFr) {
            location.replace("/fr" + (path === "/" ? "" : path));
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="min-h-screen bg-bg font-sans text-text antialiased transition-colors">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:text-on-accent"
    >
      Skip to content
    </a>
    <Header localeAlternates={localeAlternates} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-reveal: reveal [data-reveal] elements as they enter the viewport.
      const els = document.querySelectorAll("[data-reveal]");
      if (els.length && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.08 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
