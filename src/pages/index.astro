---
// English home page (served at /). Assembles the reusable content components
// from the data model. The hero profile photo + final polish land in Phase 4.
import Layout from "../layouts/Layout.astro";
import Section from "../components/ui/Section.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import SeeMoreLink from "../components/ui/SeeMoreLink.astro";
import SkillBadge from "../components/content/SkillBadge.astro";
import EducationList from "../components/content/EducationList.astro";
import ExperienceList from "../components/content/ExperienceList.astro";
import ProjectGrid from "../components/content/ProjectGrid.astro";
import { siteName } from "../config/site";
import { profile } from "../data/profile";
import { mainSkills } from "../data/skills";
import { getLangFromUrl, useTranslations, localizePath, pick } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const role = pick(profile.role, lang);
const intro = pick(profile.intro, lang);
---

<Layout title={`${siteName} — ${role}`} description="Personal portfolio of Thierno DIALLO, Software Engineer.">
  <!-- Hero (profile photo is added in Phase 4). -->
  <Section>
    <p class="mb-3 font-mono text-sm uppercase tracking-widest text-accent">{role}</p>
    <h1 class="font-display text-4xl font-bold tracking-tight text-heading sm:text-6xl">{siteName}</h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">{intro}</p>

    <div class="mt-10">
      <h2 class="font-display text-lg font-bold text-heading">{t("home.mainSkills")}</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {mainSkills.map((skill) => <li><SkillBadge skill={skill} /></li>)}
      </ul>
      <div class="mt-5">
        <SeeMoreLink href={localizePath("/skills", lang)} label={t("action.seeAll")} />
      </div>
    </div>
  </Section>

  <!-- Education (few entries → shown in full, no "see more"). -->
  <Section tone="alt">
    <SectionHeading title={t("nav.education")} />
    <div class="mt-10"><EducationList /></div>
  </Section>

  <!-- Top Experiences ∥ Top Projects (side-by-side on desktop, stacked on mobile). -->
  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading title={t("home.topExperiences")} />
        <div class="mt-8"><ExperienceList featuredOnly limit={3} /></div>
        <div class="mt-8">
          <SeeMoreLink href={localizePath("/experience", lang)} label={t("action.seeAll")} />
        </div>
      </div>
      <div>
        <SectionHeading title={t("home.topProjects")} />
        <div class="mt-8"><ProjectGrid featuredOnly limit={3} columns={1} /></div>
        <div class="mt-8">
          <SeeMoreLink href={localizePath("/projects", lang)} label={t("action.seeAll")} />
        </div>
      </div>
    </div>
  </Section>
</Layout>
