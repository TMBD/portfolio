---
/**
 * CvButton — compact "Download CV" action for the header utility cluster and a
 * full-label version for the footer. Points at the CV PDF in /public.
 */
import { cvUrl } from "../../config/site";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

interface Props {
  /** "compact" = icon + short label (header); "full" = icon + full label. */
  variant?: "compact" | "full";
  class?: string;
}

const { variant = "compact", class: className = "" } = Astro.props;
const t = useTranslations(getLangFromUrl(Astro.url));
const label = t("action.downloadCv");
---

<a
  href={cvUrl}
  download
  aria-label={label}
  title={label}
  class:list={[
    "inline-flex items-center gap-2 rounded-lg border border-border px-3 py-1.5 text-sm font-medium text-text transition-colors hover:border-accent hover:text-accent",
    className,
  ]}
>
  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l-4-4m4 4l4-4M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2" />
  </svg>
  {variant === "full" ? <span>{label}</span> : <span class="hidden sm:inline">CV</span>}
</a>
