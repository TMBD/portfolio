---
/**
 * SectionHeading — a consistent heading block for page sections, with an
 * optional eyebrow (small accent label) and subtitle.
 */
interface Props {
  title: string;
  eyebrow?: string;
  subtitle?: string;
  align?: "left" | "center";
  /** Heading level — use "h1" for the main heading of a dedicated page. */
  as?: "h1" | "h2";
  class?: string;
}

const {
  title,
  eyebrow,
  subtitle,
  align = "left",
  as: Heading = "h2",
  class: className = "",
} = Astro.props;

const alignment = align === "center" ? "mx-auto text-center" : "text-left";
---

<div data-reveal class:list={["max-w-2xl", alignment, className]}>
  {
    eyebrow && (
      <p class="mb-2 font-mono text-sm font-medium uppercase tracking-widest text-accent">
        {eyebrow}
      </p>
    )
  }
  <Heading class="font-display text-3xl font-bold tracking-tight text-heading sm:text-4xl">
    {title}
  </Heading>
  {subtitle && <p class="mt-4 text-lg text-muted">{subtitle}</p>}
</div>
