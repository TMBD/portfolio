---
/**
 * SeeMoreLink — the consistent "See all →" affordance. It signals that a
 * previewed list (skills, top experiences, top projects) has more content
 * behind its dedicated page. Reused everywhere for a consistent UX.
 */
interface Props {
  href: string;
  label: string;
  class?: string;
}

const { href, label, class: className = "" } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group inline-flex items-center gap-2 font-medium text-accent transition-colors hover:text-accent-hover",
    className,
  ]}
>
  <span>{label}</span>
  <!-- Arrow nudges right on hover — a small, lively micro-interaction. -->
  <svg
    class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
  </svg>
</a>
