---
/**
 * Header — sticky site header: brand (→ home), primary navigation, and a
 * utility cluster (language · theme · CV). Theme-aware and localized. The
 * mobile menu is toggled with a small inline script — no framework needed.
 */
import type { Lang } from "../../i18n/ui";
import { navItems, siteName } from "../../config/site";
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  isActivePath,
} from "../../i18n/utils";
import ThemeToggle from "../theme/ThemeToggle.astro";
import LanguageSwitcher from "../i18n/LanguageSwitcher.astro";
import CvButton from "../ui/CvButton.astro";

interface Props {
  /** Optional per-locale override URLs passed down to the language switcher. */
  localeAlternates?: Partial<Record<Lang, string>>;
}
const { localeAlternates } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
const homeHref = localizePath("/", lang);

const links = navItems.map((item) => {
  const href = localizePath(item.path, lang);
  return { label: t(item.labelKey), href, active: isActivePath(currentPath, href) };
});
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md transition-colors">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
    <!-- Brand → home -->
    <a href={homeHref} class="flex items-center gap-1 font-display text-lg font-bold text-heading">
      <span class="font-mono text-accent">&lt;</span>
      <span>{siteName}</span>
      <span class="font-mono text-accent">/&gt;</span>
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={l.active ? "page" : undefined}
            class:list={[
              "text-sm font-medium transition-colors",
              l.active ? "text-accent" : "text-muted hover:text-heading",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <!-- Utility cluster + mobile toggle -->
    <div class="flex items-center gap-2">
      <div class="hidden items-center gap-2 lg:flex">
        <LanguageSwitcher alternates={localeAlternates} />
        <ThemeToggle />
        <CvButton />
      </div>
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border text-text lg:hidden"
        aria-label={t("nav.menu")}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu: absolutely positioned so it overlays the page (never
       reflows content, even at scroll-top) and animates in/out via
       opacity/translate/visibility utilities. -->
  <div
    id="mobile-menu"
    class="invisible pointer-events-none absolute inset-x-0 top-full -translate-y-2 border-t border-border bg-bg/95 px-6 py-4 opacity-0 backdrop-blur-lg lg:hidden motion-safe:transition-all motion-safe:duration-300 motion-safe:ease-out"
  >
    <nav class="flex flex-col gap-3" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={l.active ? "page" : undefined}
            class:list={[
              "py-1 text-base font-medium transition-colors",
              l.active ? "text-accent" : "text-text hover:text-accent",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
    <div class="mt-4 flex items-center gap-2 border-t border-border pt-4">
      <LanguageSwitcher alternates={localeAlternates} />
      <ThemeToggle />
      <CvButton />
    </div>
  </div>
</header>

<script>
  // Mobile menu (MPA navigation re-runs this on each page load). The menu
  // overlays the page and animates through opacity/translate/visibility
  // utilities, so opening it toggles those closed-state classes rather than
  // `display`.
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const closedClasses = ["invisible", "pointer-events-none", "opacity-0", "-translate-y-2"];

  const setMenu = (open: boolean) => {
    if (!btn || !menu) return;
    closedClasses.forEach((cls) => menu.classList.toggle(cls, !open));
    btn.setAttribute("aria-expanded", String(open));
  };

  // Hamburger toggles the menu; stop the event so the outside-click handler
  // below doesn't immediately re-close it in the same tick.
  btn?.addEventListener("click", (event) => {
    event.stopPropagation();
    setMenu(btn.getAttribute("aria-expanded") !== "true");
  });

  // Dismiss the menu when clicking outside it, or when pressing Escape.
  document.addEventListener("click", (event) => {
    if (btn?.getAttribute("aria-expanded") !== "true") return;
    const target = event.target as Node;
    if (!menu?.contains(target) && !btn?.contains(target)) setMenu(false);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenu(false);
  });
</script>
