---
/**
 * EducationItem — one diploma in the same timeline style as experiences:
 * degree + institution + description, with the period on the right.
 */
import type { Education } from "../../data/types";
import { getLangFromUrl, pick } from "../../i18n/utils";

interface Props {
  item: Education;
}
const { item } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<article class="relative border-l-2 border-accent/50 pl-6">
  <span class="absolute -left-[7px] top-2 h-3 w-3 rounded-full bg-accent"></span>
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
    <h3 class="font-display text-xl font-bold text-heading">{pick(item.degree, lang)}</h3>
    <span class="shrink-0 font-mono text-sm text-accent">{pick(item.period, lang)}</span>
  </div>
  <p class="text-lg text-muted">{item.institution}</p>
  <p class="mt-2 leading-relaxed text-muted">{pick(item.description, lang)}</p>
</article>
