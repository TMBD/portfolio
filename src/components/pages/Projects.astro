---
/**
 * Projects page body (shared by EN `/projects` and FR `/fr/projects`).
 * Full grid of projects (no limit).
 */
import Layout from "../../layouts/Layout.astro";
import Section from "../ui/Section.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import ProjectGrid from "../content/ProjectGrid.astro";
import { siteName } from "../../config/site";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t("nav.projects")} — ${siteName}`} description={t("page.projects.subtitle")}>
  <Section>
    <SectionHeading title={t("nav.projects")} subtitle={t("page.projects.subtitle")} />
    <div class="mt-12"><ProjectGrid /></div>
  </Section>
</Layout>
