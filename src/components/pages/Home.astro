---
/**
 * Home page body (shared by the EN `/` and FR `/fr/` routes).
 * Locale is detected from the URL, so both routes render this one component.
 */
import Layout from "../../layouts/Layout.astro";
import Section from "../ui/Section.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import SeeMoreLink from "../ui/SeeMoreLink.astro";
import SkillBadge from "../content/SkillBadge.astro";
import EducationList from "../content/EducationList.astro";
import ExperienceList from "../content/ExperienceList.astro";
import ProjectGrid from "../content/ProjectGrid.astro";
import { siteName } from "../../config/site";
import { profile } from "../../data/profile";
import { mainSkills } from "../../data/skills";
import { getLangFromUrl, useTranslations, localizePath, pick } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const role = pick(profile.role, lang);
const intro = pick(profile.intro, lang);
const description =
  lang === "fr"
    ? "Portfolio personnel de Thierno DIALLO, ingénieur logiciel."
    : "Personal portfolio of Thierno DIALLO, Software Engineer.";
---

<Layout title={`${siteName} — ${role}`} description={description}>
  <!-- Hero -->
  <Section>
    <div class="grid items-center gap-10 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <p class="mb-3 font-mono text-sm uppercase tracking-widest text-accent">{role}</p>
        <h1 class="font-display text-4xl font-bold tracking-tight text-heading sm:text-6xl">{siteName}</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">{intro}</p>

        <!-- Main Technical Skills preview -->
        <div class="mt-10">
          <h2 class="font-display text-lg font-bold text-heading">{t("home.mainSkills")}</h2>
          <ul class="mt-4 flex flex-wrap gap-2">
            {mainSkills.map((skill) => <li><SkillBadge skill={skill} /></li>)}
          </ul>
          <div class="mt-5">
            <SeeMoreLink href={localizePath("/skills", lang)} label={t("action.seeAll")} />
          </div>
        </div>
      </div>

      <!-- Profile photo (placeholder — replace via src/data/profile.ts) -->
      <div class="order-first flex justify-center lg:order-last lg:justify-end">
        <div class="relative">
          <div class="absolute -inset-4 rounded-full bg-accent/15 blur-2xl" aria-hidden="true"></div>
          <img
            src={profile.photo}
            alt={profile.name}
            width="320"
            height="320"
            class="relative aspect-square w-52 rounded-2xl border border-border object-cover shadow-xl sm:w-64 lg:w-72"
          />
        </div>
      </div>
    </div>
  </Section>

  <!-- Education (few entries → shown in full) -->
  <Section tone="alt">
    <SectionHeading title={t("nav.education")} />
    <div class="mt-10"><EducationList /></div>
  </Section>

  <!-- Top Experiences ∥ Top Projects -->
  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading title={t("home.topExperiences")} />
        <div class="mt-8"><ExperienceList featuredOnly limit={3} /></div>
        <div class="mt-8">
          <SeeMoreLink href={localizePath("/experience", lang)} label={t("action.seeAll")} />
        </div>
      </div>
      <div>
        <SectionHeading title={t("home.topProjects")} />
        <div class="mt-8"><ProjectGrid featuredOnly limit={3} columns={1} /></div>
        <div class="mt-8">
          <SeeMoreLink href={localizePath("/projects", lang)} label={t("action.seeAll")} />
        </div>
      </div>
    </div>
  </Section>
</Layout>
